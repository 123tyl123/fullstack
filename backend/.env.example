APP_ENV=debug
SERVER_PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=fullstack
DB_CHARSET=utf8mb4
DB_PARSE_TIME=true
DB_LOC=Local
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_CONN_MAX_LIFETIME_MINUTES=60

JWT_ACCESS_SECRET=dev-secret-change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PATH=/api/uploads
AVATAR_MAX_SIZE_MB=5

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
